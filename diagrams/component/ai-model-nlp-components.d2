# C4 Level 3 — Components (example: AI/NLP Service)
# Zoom into a single container from the container diagram.

direction: right

nlp: AI/NLP Service {
  api: Inference API
  intent: Intent Classifier
  ranker: Recommendation Ranker
  store: Model / Feature Store {
    shape: cylinder
  }
}

nlp.api -> nlp.intent: Classify request
nlp.api -> nlp.ranker: Rank options
nlp.intent -> nlp.store: Load model
nlp.ranker -> nlp.store: Load features
